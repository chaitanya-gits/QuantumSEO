{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "outDir": "dist"
  },
  "include": [
    "*.d.ts",
    "ai/**/*.ts",
    "api/**/*.ts",
    "crawler/**/*.ts",
    "frontend/**/*.tsx",
    "gateway/**/*.ts",
    "indexer/**/*.ts",
    "infrastructure/**/*.ts",
    "ranking/**/*.ts",
    "retrieval/**/*.ts"
  ]
}
